rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user's email exists in the approvedUsers collection AND has active == true
    function isApprovedAndActive() {
      return exists(/databases/$(database)/documents/approvedUsers/$(request.auth.token.email))
             && get(/databases/$(database)/documents/approvedUsers/$(request.auth.token.email)).data.active == true;
    }
    
    // Restrict access to the user's own data path AND require them to be approved and active
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId 
                         && isApprovedAndActive();
    }

    // Explicitly block all other access (default is deny, but this is explicit)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
